{
  "name": "nova-os",
  "version": "0.1.0",
  "description": "NOVA OS — AI-Native Operating System",
  "main": "main.js",
  "author": "NOVA OS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/viraajbindra-a11y/Nova-OS.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.novaos.desktop",
    "productName": "NOVA OS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icons/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": ["AppImage", "deb"],
      "category": "System"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeaderIcon": "icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NOVA OS"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "express": "^4.21.0"
  }
}
